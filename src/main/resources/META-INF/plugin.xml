<idea-plugin>
    <id>com.luisppb16.openapi-generator</id>
    <name>OpenAPI SpecTacular</name>
    <vendor email="ironkrozz@gmail.com" url="https://github.com/luisppb16">Luis Pepe</vendor>
    <description><![CDATA[
        <p>Generate realistic example objects from your OpenAPI specifications.</p>
        <p>Features:</p>
        <ul>
            <li>Parse OpenAPI 3.x and Swagger 2.x specifications (YAML and JSON)</li>
            <li>Select the number of examples to generate per schema</li>
            <li>Overall counter for total examples</li>
            <li>Generates valid JSON examples with realistic data</li>
            <li>Modern, intuitive UI integrated with IntelliJ IDEA</li>
        </ul>
    ]]></description>

    <idea-version since-build="251" until-build="261.*"/>
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="OpenAPI Generator"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
    </extensions>

    <actions>
        <group id="OpenAPIGeneratorGroup" text="OpenAPI SpecTacular" popup="true" icon="AllIcons.FileTypes.Json">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="com.openapi.generator.GenerateExamplesAction"
                    class="com.luisppb16.openapi.generator.ui.action.GenerateExamplesAction"
                    text="Generate Examples from OpenAPI Specification"
                    description="Open a dialog to generate example objects from an OpenAPI specification"
                    icon="AllIcons.Actions.GeneratedFolder"/>
        </group>
        <action id="com.openapi.generator.GenerateExamplesAction.EditorContext"
                class="com.luisppb16.openapi.generator.ui.action.GenerateExamplesAction"
                text="Generate Examples from OpenAPI Specification"
                description="Generate example objects from this OpenAPI specification"
                icon="AllIcons.Actions.GeneratedFolder">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
